#ifndef SECRETS_H
#define SECRETS_H

// ================================================================
//  WiFi CREDENTIALS
// ================================================================
#define WIFI_SSID      "your_wifi_ssid"
#define WIFI_PASSWORD  "your_wifi_password"

// ================================================================
//  FIREBASE CREDENTIALS
// ================================================================
#define FIREBASE_API_KEY      "your_firebase_api_key"
#define FIREBASE_DATABASE_URL "https://your-project-default-rtdb.region.firebasedatabase.app/"

// ================================================================
//  TWILIO CREDENTIALS
// ================================================================
#define TWILIO_ACCOUNT_SID   "your_twilio_account_sid"
#define TWILIO_AUTH_TOKEN    "your_twilio_auth_token"
#define TWILIO_FROM_NUMBER   "+1XXXXXXXXXX"
#define TWILIO_TO_USER       "+91XXXXXXXXXX"
#define TWILIO_TO_DOCTOR     "+91XXXXXXXXXX"

#endif // SECRETS_H
